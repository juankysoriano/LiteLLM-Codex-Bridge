[Unit]
Description=LiteLLM-Codex-Bridge — local proxy that lets Codex talk to LiteLLM/vLLM
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# Edit these two paths to match your install:
WorkingDirectory=%h/.config/litellm-codex-bridge
ExecStart=%h/.local/bin/uv run --quiet %h/.config/litellm-codex-bridge/bridge.py

# Where to read your upstream API key from. The bridge itself doesn't read
# the key — it just forwards the Authorization header from Codex. But Codex
# reads its key via env (X_NAN_KEY for NaN, OPENAI_API_KEY for OpenAI, etc),
# so this systemd unit doesn't need any secret. Leave commented unless you
# want to override the default upstream URL.
# Environment=BRIDGE_UPSTREAM_URL=https://api.nan.builders/v1
# Environment=PORT=4100
# Environment=HOST=127.0.0.1
# Environment=LOG_LEVEL=info

Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
